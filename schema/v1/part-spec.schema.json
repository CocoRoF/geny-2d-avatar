{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geny.ai/schema/v1/part-spec.schema.json",
  "title": "Part Spec",
  "description": "docs/04 §3. 파츠 슬롯의 계약서. AI 생성·후처리·검수가 모두 참조.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "slot_id",
    "role",
    "required",
    "template",
    "template_version",
    "deformation_parent",
    "category",
    "uv_box_px",
    "canvas_px",
    "anchor",
    "z_order",
    "visual",
    "generation",
    "validation"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "v1" },
    "slot_id": { "$ref": "common/ids.json#/$defs/slotId" },
    "role": {
      "type": "string",
      "description": "시맨틱 역할. 보통 slot_id 의 카테고리 부분."
    },
    "required": { "type": "boolean" },
    "template": { "$ref": "common/ids.json#/$defs/templateRef" },
    "template_version": {
      "type": "string",
      "pattern": "^\\^?[0-9]+(?:\\.[0-9]+)?(?:\\.[0-9]+)?$",
      "description": "이 스펙이 보장하는 템플릿 major 범위. 예: `^1`."
    },
    "deformation_parent": {
      "type": "string",
      "description": "디포머 트리에서 이 파츠의 부모. docs/03 §4.1.",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": ["face", "eye", "brow", "mouth", "hair", "body", "cloth", "accessory", "fx"],
      "description": "docs/04 §2.1 표의 category 컬럼."
    },
    "canvas_px": {
      "type": "object",
      "additionalProperties": false,
      "required": ["w", "h"],
      "properties": {
        "w": { "type": "integer", "enum": [2048, 4096] },
        "h": { "type": "integer", "enum": [2048, 4096] }
      }
    },
    "uv_box_px": {
      "type": "object",
      "description": "이 파츠가 점유하는 캔버스 내 박스 (x,y,w,h). 픽셀 단위.",
      "additionalProperties": false,
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "w": { "type": "integer", "exclusiveMinimum": 0 },
        "h": { "type": "integer", "exclusiveMinimum": 0 }
      }
    },
    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "x_frac", "y_frac", "detect_method"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "bbox_center",
            "alpha_centroid",
            "eye_pupil_center_l",
            "eye_pupil_center_r",
            "mouth_center",
            "nose_tip",
            "head_top_center",
            "hair_parting_centroid",
            "neck_top_center",
            "shoulder_l",
            "shoulder_r"
          ]
        },
        "x_frac": { "type": "number", "minimum": 0, "maximum": 1 },
        "y_frac": { "type": "number", "minimum": 0, "maximum": 1 },
        "detect_method": { "type": "string", "minLength": 1 }
      }
    },
    "z_order": { "type": "integer" },
    "symmetry": {
      "type": "object",
      "additionalProperties": false,
      "description": "좌우 대칭 관계. docs/04 §12.1.",
      "properties": {
        "pair_with": { "$ref": "common/ids.json#/$defs/slotId" },
        "mirror_uv": { "type": "boolean", "default": true }
      }
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "description": "A/B 대체 포즈(docs/03 §12.1, docs/04 §2.4).",
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z]$" },
        "mutex_group": { "type": "string", "description": "Cubism Pose3 mutex 그룹 이름." }
      }
    },
    "visual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alpha_edge_policy", "line_weight_hint_px", "color_context"],
      "properties": {
        "alpha_edge_policy": {
          "type": "string",
          "enum": ["hard", "feather_1px", "feather_2px", "feather_4px"]
        },
        "line_weight_hint_px": { "type": "number", "minimum": 0 },
        "color_context": {
          "type": "string",
          "enum": ["skin", "hair", "eye", "cloth_main", "cloth_accent", "accessory", "metal", "glass", "fx"],
          "description": "docs/04 §5 색 문맥 그룹."
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt_scope", "negative_prompt", "max_iter"],
      "properties": {
        "prompt_scope": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "이 슬롯이 허용하는 프롬프트 필드."
        },
        "negative_prompt": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reference_mask": {
          "type": "string",
          "description": "마스크 파일 상대경로."
        },
        "max_iter": { "type": "integer", "minimum": 1, "maximum": 10 }
      }
    },
    "dependencies": {
      "type": "array",
      "items": { "$ref": "common/ids.json#/$defs/slotId" },
      "description": "docs/04 §8. 상위 파츠 없이 생성 금지."
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["must_cover_anchor"],
      "properties": {
        "must_cover_anchor": { "type": "boolean" },
        "min_alpha_area_frac": { "type": "number", "minimum": 0, "maximum": 1 },
        "max_alpha_area_frac": { "type": "number", "minimum": 0, "maximum": 1 },
        "forbidden_colors": {
          "type": "array",
          "items": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
        }
      }
    },
    "cubism_part_id": {
      "$ref": "common/ids.json#/$defs/cubismPartId",
      "description": "Cubism export 시 사용할 Part ID. 미지정 시 생성기 규칙대로."
    },
    "notes": { "type": "string" }
  }
}
