{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geny.ai/schema/v1/adapter-catalog.schema.json",
  "title": "AdapterCatalog",
  "description": "docs/05 §12.6 — AI 어댑터 카탈로그. orchestrator 가 이 파일을 읽어 AdapterRegistry 를 구성한다. name+version 이 고유 키. factory 는 JSON 에 표현하지 않고 코드에서 주입한다(런타임 객체). `config` 는 각 어댑터의 비밀·엔드포인트(있다면 env 변수 참조키)만 들고, 비밀 값 자체는 담지 않는다. Foundation 단계는 YAML 대신 JSON 으로 확정 — 스키마-우선 원칙(ADR 0002) 일관성 + 기존 validate-schemas 파이프라인 재활용.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "adapters"],
  "properties": {
    "schema_version": { "type": "string", "const": "v1" },
    "adapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "version",
          "capability",
          "cost_per_call_usd",
          "max_parallel",
          "routing_weight"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{1,63}$",
            "description": "어댑터 식별자(소문자/숫자/하이픈). 예: `nano-banana`, `sdxl`, `flux-fill`."
          },
          "version": { "$ref": "common/ids.json#/$defs/semver" },
          "capability": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": ["edit", "style_ref", "mask", "seg", "kp", "upscale", "embed"]
            }
          },
          "cost_per_call_usd": {
            "type": "number",
            "minimum": 0,
            "description": "파츠 1회 호출 기준 참고 비용. 실제 estimateCost() 는 어댑터가 task 별로 계산하되, 라우팅 정렬의 사전 힌트로 사용."
          },
          "max_parallel": {
            "type": "integer",
            "minimum": 1,
            "maximum": 64,
            "description": "어댑터별 동시 호출 상한. 세마포어/배치 스케줄러가 이 값을 강제."
          },
          "routing_weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1000,
            "description": "AdapterRegistry.route() 의 1차 정렬 키. 값이 클수록 먼저 시도. 헬스 스코어 감점 로직은 orchestrator 상위에서 처리."
          },
          "config": {
            "type": "object",
            "additionalProperties": false,
            "description": "어댑터별 런타임 설정. 비밀은 env 변수 참조키만 둔다(값 자체는 담지 않음).",
            "properties": {
              "endpoint": { "type": "string", "minLength": 1, "maxLength": 256 },
              "api_key_env": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]{1,63}$" },
              "model": { "type": "string", "minLength": 1, "maxLength": 64 },
              "timeout_ms": { "type": "integer", "minimum": 1000, "maximum": 600000 }
            }
          },
          "enabled": {
            "type": "boolean",
            "description": "false 이면 카탈로그는 파싱하되 레지스트리에 등록하지 않는다. A/B 토글용. 기본 true."
          }
        }
      }
    }
  }
}
