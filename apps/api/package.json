{
  "name": "@geny/api",
  "version": "0.1.0",
  "private": true,
  "description": "Geny 2D Avatar 백엔드 API - Phase 2 (docs/03-ARCHITECTURE.md §3.2). Fastify 기반으로 프리셋 카탈로그 / 텍스처 업로드·생성 / 번들 빌드·다운로드 엔드포인트 제공.",
  "type": "module",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:test": "tsc -p tsconfig.test.json",
    "clean": "rm -rf dist dist-test",
    "dev": "pnpm build && node --env-file-if-exists=../../.env --env-file-if-exists=.env dist/server.js",
    "start": "node --env-file-if-exists=../../.env --env-file-if-exists=.env dist/server.js",
    "test": "pnpm build:test && node --test --test-reporter=spec 'dist-test/tests/**/*.test.js'"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@geny/exporter-core": "workspace:^",
    "archiver": "^7.0.1",
    "fastify": "^5.2.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/archiver": "^6",
    "@types/node": "^20.11.30",
    "@types/pngjs": "^6",
    "typescript": "^5.6.3"
  }
}
