{
  "uid": "geny-cost",
  "title": "Geny — Cost",
  "description": "docs/02 §9.2 #2 — 벤더별 호출/비용, 1아바타당 단가, 캐시 적중률. 질문: '지금 돈이 얼마나 새고 있나?'",
  "tags": ["geny", "foundation", "cost", "finance"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "시간당 AI 비용 (1h)",
      "description": "sum(rate(geny_ai_call_cost_usd[1h])) * 3600 — 현재 시간당 USD.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(geny_ai_call_cost_usd[1h])) * 3600",
          "legendFormat": "USD/h"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "1아바타당 평균 단가 (1h)",
      "description": "geny_cost_per_avatar_usd — 재무 모니터링 지표.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2.0 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(geny_cost_per_avatar_usd)",
          "legendFormat": "USD/avatar"
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "캐시 적중률 (5m)",
      "description": "L1_redis + L2_s3 + cdn 통합. 재생성 억제의 핵심 지표.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(geny_cache_hit_total[5m])) / clamp_min(sum(rate(geny_cache_hit_total[5m])) + sum(rate(geny_cache_miss_total[5m])), 1)",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "벤더별 호출 수 (5m rate)",
      "description": "geny_ai_call_total — 벤더 분포 및 비정상 급등 탐지.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "stacking": { "mode": "normal", "group": "A" },
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (vendor) (rate(geny_ai_call_total[5m]))",
          "legendFormat": "{{vendor}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "벤더별 비용 (5m rate, USD/s)",
      "description": "geny_ai_call_cost_usd — 월간 예측 시 sum_over_time 사용.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "stacking": { "mode": "normal", "group": "A" },
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (vendor) (rate(geny_ai_call_cost_usd[5m]))",
          "legendFormat": "{{vendor}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "예산 사용률 (스코프별)",
      "description": "geny_cost_budget_used_ratio — 0.9 이상 P2 알람 대상.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1.2,
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "geny_cost_budget_used_ratio",
          "legendFormat": "{{budget_scope}}"
        }
      ]
    }
  ]
}
