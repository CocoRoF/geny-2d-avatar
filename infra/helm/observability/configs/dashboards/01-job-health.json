{
  "uid": "geny-job-health",
  "title": "Geny — Job Health",
  "description": "docs/02 §9.2 #1 — WSAC, 완주율, p50/p90 TTFE, 실패 상위10. 질문: '완주율이 떨어지고 있나?'",
  "tags": ["geny", "foundation", "job", "slo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "WSAC (7일 성공 job)",
      "description": "Weekly Successful Avatar Completions — docs/01 §5 성장 지표.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(geny_job_completed_total{status=\"success\"}[7d]))",
          "legendFormat": "WSAC"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "완주율 (5m)",
      "description": "success / started. P1 알람: 10분간 -15%p 하락.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(geny_job_completed_total{status=\"success\"}[5m])) / clamp_min(sum(rate(geny_job_started_total[5m])), 1)",
          "legendFormat": "완주율"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "진행 중 Job",
      "description": "geny_jobs_inflight — 큐 길이와 함께 USE 신호.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(geny_jobs_inflight)",
          "legendFormat": "inflight"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "완주율 추이",
      "description": "템플릿별 완주율. P1 알람 대응 시 원인 분해.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (template_family) (rate(geny_job_completed_total{status=\"success\"}[5m])) / clamp_min(sum by (template_family) (rate(geny_job_started_total[5m])), 1)",
          "legendFormat": "{{template_family}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "TTFE 분위수 (p50 / p90 / p99)",
      "description": "Time-To-First-Export. 목표: p50 ≤ 30분, p90 ≤ 2시간.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(geny_job_ttfe_seconds_bucket[1h])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.90, sum by (le) (rate(geny_job_ttfe_seconds_bucket[1h])))",
          "legendFormat": "p90"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(geny_job_ttfe_seconds_bucket[1h])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "실패 원인 상위 10 (1h)",
      "description": "geny_job_failed_reason_total — 원인별 실패 수. 알람 후 원인 분해 용.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": { "align": "auto" }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Value", "desc": true }]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (reason, stage) (increase(geny_job_failed_reason_total[1h])))",
          "legendFormat": "{{reason}} @ {{stage}}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "renameByName": { "reason": "원인", "stage": "스테이지", "Value": "실패 수 (1h)" }
          }
        }
      ]
    }
  ]
}
