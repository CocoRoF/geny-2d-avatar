{
  "schema_version": "v1",
  "root_id": "root",
  "nodes": [
    {
      "id": "root",
      "type": "warp",
      "parent": null,
      "params_in": [],
      "notes": "아바타 루트. 모든 가시 서브트리는 overall_warp 하위. v1.2.0 부터 overall_x/y/rotate 는 runtime 주입이 아닌 명시 deformer(overall_warp) 로 연결."
    },
    {
      "id": "overall_warp",
      "type": "warp",
      "parent": "root",
      "params_in": ["overall_x", "overall_y", "overall_rotate"],
      "notes": "화면 내 프레이밍용 전체 변환. 모델 전체 트리를 감싸며, 자식: breath_warp, hair_back_warp. docs/03 §12.1 #6."
    },
    {
      "id": "breath_warp",
      "type": "warp",
      "parent": "overall_warp",
      "params_in": ["body_breath"],
      "notes": "호흡 루프. idle.default 의 주 입력."
    },
    {
      "id": "body_pose_warp",
      "type": "warp",
      "parent": "breath_warp",
      "params_in": ["body_angle_x", "body_angle_y", "body_angle_z"],
      "notes": "상반신 3축 회전."
    },
    {
      "id": "body_visual",
      "type": "warp",
      "parent": "body_pose_warp",
      "params_in": [],
      "notes": "상반신 파츠 묶음(컨테이너). 직접 자식 파츠: torso. cloth_main 은 cloth_warp 하위. 팔은 arm_l_warp / arm_r_warp 하위."
    },
    {
      "id": "cloth_warp",
      "type": "warp",
      "parent": "body_visual",
      "params_in": ["cloth_main_fuwa"],
      "notes": "의상 볼륨 팽창 warp. 자식 파츠: cloth_main. 추후 cloth_outer/cloth_inner 확장 시 같은 warp 아래로 묶음."
    },
    {
      "id": "arm_l_warp",
      "type": "warp",
      "parent": "body_visual",
      "params_in": ["arm_l_angle"],
      "notes": "캐릭터 왼팔 회전 warp. 자식 파츠: arm_l_a, arm_l_b (Pose3 mutex 로 동시 노출 금지)."
    },
    {
      "id": "arm_r_warp",
      "type": "warp",
      "parent": "body_visual",
      "params_in": ["arm_r_angle"],
      "notes": "캐릭터 오른팔 회전 warp. 자식 파츠: arm_r_a, arm_r_b."
    },
    {
      "id": "neck_warp",
      "type": "warp",
      "parent": "body_pose_warp",
      "params_in": [],
      "notes": "목 컨테이너. 자식 파츠: neck."
    },
    {
      "id": "head_pose_rot",
      "type": "warp",
      "parent": "neck_warp",
      "params_in": ["head_angle_x", "head_angle_y", "head_angle_z"],
      "notes": "머리 3축 회전. 자식 파츠: face_base, face_shadow, cheek_blush, brow_l, brow_r, nose. CombinedParam (head_angle_x, head_angle_y) 2D 조이스틱 대응."
    },
    {
      "id": "eye_l_warp",
      "type": "warp",
      "parent": "head_pose_rot",
      "params_in": ["eye_open_l", "eye_smile_l", "eye_form_l", "eye_ball_x", "eye_ball_y", "eye_ball_form"],
      "notes": "캐릭터 왼눈. 자식 파츠: eye_white_l, eye_iris_l, eye_lash_upper_l, eye_lash_lower_l."
    },
    {
      "id": "eye_r_warp",
      "type": "warp",
      "parent": "head_pose_rot",
      "params_in": ["eye_open_r", "eye_smile_r", "eye_form_r", "eye_ball_x", "eye_ball_y", "eye_ball_form"],
      "notes": "캐릭터 오른눈. eye_ball_x/y/form 은 양 눈 공용."
    },
    {
      "id": "mouth_warp",
      "type": "warp",
      "parent": "head_pose_rot",
      "params_in": ["mouth_vowel_a", "mouth_vowel_i", "mouth_vowel_u", "mouth_vowel_e", "mouth_vowel_o", "mouth_up", "mouth_down"],
      "notes": "입. 립싱크 5 모음 + 입꼬리 2. 자식 파츠: mouth_base, mouth_inner."
    },
    {
      "id": "hair_front_warp",
      "type": "warp",
      "parent": "head_pose_rot",
      "params_in": ["hair_front_sway", "hair_front_fuwa"],
      "notes": "앞머리. sway(회전 흔들림) + fuwa(볼륨) 2 물리 출력 바인딩. 자식 파츠: hair_front."
    },
    {
      "id": "hair_side_warp_l",
      "type": "warp",
      "parent": "head_pose_rot",
      "params_in": ["hair_side_sway_l", "hair_side_fuwa_l"],
      "notes": "캐릭터 왼쪽 옆머리. sway + fuwa."
    },
    {
      "id": "hair_side_warp_r",
      "type": "warp",
      "parent": "head_pose_rot",
      "params_in": ["hair_side_sway_r", "hair_side_fuwa_r"],
      "notes": "캐릭터 오른쪽 옆머리. sway + fuwa. L/R 은 독립 시뮬(physics PhysicsSetting2/3, Fuwa 6/7)."
    },
    {
      "id": "accessories_layer",
      "type": "warp",
      "parent": "head_pose_rot",
      "params_in": [],
      "notes": "머리 움직임을 따라가는 액세서리 레이어(모자, 헤드폰 등). 자식 파츠: accessory_front, accessory_back. body-level 액세서리 분리는 후속 bump."
    },
    {
      "id": "hair_back_warp",
      "type": "warp",
      "parent": "overall_warp",
      "params_in": ["hair_back_sway", "hair_back_fuwa"],
      "notes": "docs/03 §4.2 — 뒷머리는 머리/상반신 pose warp 외부. v1.2.0 부터는 overall_warp 직속으로 이동해 전체 평행이동은 공유하되 head/body 회전 지연 특성 유지. sway + fuwa."
    }
  ]
}
