{
  "schema_version": "v1",
  "slot_id": "cheek_blush",
  "role": "cheek_blush",
  "required": false,
  "template": "tpl.base.v1.fullbody",
  "template_version": "^1",
  "deformation_parent": "head_pose_rot",
  "category": "face",
  "canvas_px": { "w": 2048, "h": 2048 },
  "uv_box_px": { "x": 720, "y": 800, "w": 640, "h": 192 },
