  "dependencies": ["face_base"],
  "validation": {
    "must_cover_anchor": false,
    "min_alpha_area_frac": 0.05,
    "max_alpha_area_frac": 0.60
  },
  "cubism_part_id": "PartCheekBlush",
  "notes": "좌우 뺨에 분산 배치. cheek_blush 파라미터(확장)로 불투명도 제어."
