{
  "schema_version": "v1",
  "slot_id": "face_shadow",
  "role": "face_shadow",
  "required": true,
  "template": "tpl.base.v1.fullbody",
  "template_version": "^1",
  "deformation_parent": "head_pose_rot",
  "category": "face",
  "canvas_px": { "w": 2048, "h": 2048 },
  "uv_box_px": { "x": 560, "y": 304, "w": 928, "h": 1056 },
  "anchor": {
    "type": "bbox_center",
    "x_frac": 0.5,
    "y_frac": 0.5,
    "detect_method": "alpha_bbox_center_v1"
  },
  "z_order": 60,
  "visual": {
    "alpha_edge_policy": "feather_4px",
    "line_weight_hint_px": 0,
    "color_context": "shadow"
  },
  "generation": {
    "prompt_scope": ["shadow_intensity", "shadow_style", "light_direction"],
    "negative_prompt": ["hair", "eyes", "mouth", "text", "watermark"],
    "reference_mask": "masks/face_shadow_mask.png",
    "max_iter": 2
  },
  "dependencies": ["face_base"],
  "validation": {
    "must_cover_anchor": false,
    "min_alpha_area_frac": 0.02,
    "max_alpha_area_frac": 0.80
  },
  "cubism_part_id": "PartFaceShadow",
  "notes": "얼굴 아래로 깔리는 음영 레이어. 광원각(face_shadow 확장 파라미터)에 따라 투명도 조절."
}
