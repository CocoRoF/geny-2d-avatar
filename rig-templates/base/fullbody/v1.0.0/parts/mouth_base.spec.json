{
  "schema_version": "v1",
  "slot_id": "mouth_base",
  "role": "mouth_base",
  "required": true,
  "template": "tpl.base.v1.fullbody",
  "template_version": "^1",
  "deformation_parent": "mouth_warp",
  "category": "mouth",
  "canvas_px": { "w": 2048, "h": 2048 },
  "uv_box_px": { "x": 896, "y": 976, "w": 256, "h": 192 },
  "anchor": {
    "type": "mouth_center",
    "x_frac": 0.5,
    "y_frac": 0.5,
    "detect_method": "keypoint_model_mouth_v1"
  },
  "z_order": 86,
  "visual": {
    "alpha_edge_policy": "feather_1px",
    "line_weight_hint_px": 2.0,
    "color_context": "mouth"
  },
  "generation": {
    "prompt_scope": ["lip_shape", "lip_color", "lip_thickness"],
    "negative_prompt": ["teeth", "tongue", "beard", "text", "watermark"],
    "reference_mask": "masks/mouth_base_mask.png",
    "max_iter": 3
  },
  "dependencies": ["face_base"],
  "validation": {
    "must_cover_anchor": true,
    "min_alpha_area_frac": 0.25,
    "max_alpha_area_frac": 0.95
  },
  "cubism_part_id": "PartMouthBase",
  "notes": "립싱크 모음 5종 + mouth_up/down 에 의한 변형의 주 타깃. mouth_open 시 mouth_inner 를 드러내는 알파홀 유지."
}
