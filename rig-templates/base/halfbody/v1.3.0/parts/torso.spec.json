{
  "schema_version": "v1",
  "slot_id": "torso",
  "role": "torso",
  "required": true,
  "template": "tpl.base.v1.halfbody",
  "template_version": "^1",
  "deformation_parent": "body_visual",
  "category": "body",
  "canvas_px": { "w": 2048, "h": 2048 },
  "uv_box_px": { "x": 512, "y": 1440, "w": 1024, "h": 608 },
  "anchor": {
    "type": "neck_top_center",
    "x_frac": 0.5,
    "y_frac": 0.05,
    "detect_method": "keypoint_model_body_v1"
  },
  "z_order": 20,
  "visual": {
    "alpha_edge_policy": "feather_2px",
    "line_weight_hint_px": 2.5,
    "color_context": "skin"
  },
  "generation": {
    "prompt_scope": ["body_shape", "skin_tone", "torso_proportion"],
    "negative_prompt": ["face", "arms", "hair", "background", "text", "watermark"],
    "reference_mask": "masks/torso_mask.png",
    "max_iter": 3
  },
  "dependencies": [],
  "parameter_ids": ["body_angle_x", "body_angle_y", "body_angle_z", "body_breath", "body_breath_phys"],
  "validation": {
    "must_cover_anchor": true,
    "min_alpha_area_frac": 0.18,
    "max_alpha_area_frac": 0.85
  },
  "cubism_part_id": "PartTorso",
  "notes": "HitAreaBody 바인딩 대상. body_breath 에 의한 변형 대응. cloth_main 이 대부분 가리지만 노출 영역은 skin 문맥."
}
