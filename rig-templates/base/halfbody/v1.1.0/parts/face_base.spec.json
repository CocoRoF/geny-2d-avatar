{
  "schema_version": "v1",
  "slot_id": "face_base",
  "role": "face_base",
  "required": true,
  "template": "tpl.base.v1.halfbody",
  "template_version": "^1",
  "deformation_parent": "head_pose_rot",
  "category": "face",
  "canvas_px": { "w": 2048, "h": 2048 },
  "uv_box_px": { "x": 576, "y": 320, "w": 896, "h": 1024 },
  "anchor": {
    "type": "nose_tip",
    "x_frac": 0.5,
    "y_frac": 0.55,
    "detect_method": "keypoint_model_mediapipe_face_v1"
  },
  "z_order": 70,
  "visual": {
    "alpha_edge_policy": "feather_2px",
    "line_weight_hint_px": 2.5,
    "color_context": "skin"
  },
  "generation": {
    "prompt_scope": ["face_shape", "skin_tone", "race_hint", "age_hint"],
    "negative_prompt": ["hair", "glasses", "background", "shadows", "text", "watermark"],
    "reference_mask": "masks/face_base_mask.png",
    "max_iter": 3
  },
  "dependencies": [],
  "validation": {
    "must_cover_anchor": true,
    "min_alpha_area_frac": 0.22,
    "max_alpha_area_frac": 0.55
  },
  "cubism_part_id": "PartFaceBase",
  "notes": "얼굴 베이스는 모든 하위 얼굴 파츠의 좌표 기준. 앵커는 코 끝 기준으로 모든 아바타가 동일한 기대 위치에 정렬된다."
}
