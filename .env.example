# ============================================================================
# Geny 2D Avatar - 환경 변수 샘플
# 사용법:
#   1. 이 파일을 `.env` 로 복사: `cp .env.example .env`
#   2. 필요한 값을 채움
#   3. `pnpm -F @geny/api dev` (또는 start) 가 자동으로 로드 (Node 22.11+ --env-file-if-exists)
#
# 우선순위: 저장소 루트 `.env` → apps/api/.env (뒤에 로드된 파일이 override)
# .env / .env.* 는 .gitignore 됨 — 커밋 금지.
# ============================================================================

# ----------------------------------------------------------------------------
# AI 텍스처 생성 벤더 키 (선택)
# ----------------------------------------------------------------------------
# 둘 다 비워도 pollinations(공개 API) + mock(결정론) 폴백으로 파이프라인은 동작.
# 어댑터 우선순위 (앞=primary):
#   1. nano-banana    (GEMINI_API_KEY 또는 GOOGLE_API_KEY 있을 때)
#   2. openai-image   (OPENAI_API_KEY 있을 때)
#   3. pollinations   (키 불필요)
#   4. mock           (항상 fallback)

# Google Gemini Image (nano banana)
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=
# 또는 동일 의미:
# GOOGLE_API_KEY=

# OpenAI Images (gpt-image-1 / dall-e-3)
# https://platform.openai.com/api-keys 에서 발급
# gpt-image-1 은 organization verified 필요 (없으면 dall-e-3 fallback 권장)
OPENAI_API_KEY=

# ----------------------------------------------------------------------------
# 어댑터 모델 (선택, 기본값은 atlas-friendly)
# ----------------------------------------------------------------------------
#
# Gemini (nano-banana) — default: gemini-3.1-flash-image-preview (Nano Banana 2)
#   gemini-3.1-flash-image-preview  ← default. atlas 보존 안정적, imageConfig (aspectRatio/imageSize) 지원
#   gemini-3-pro-image-preview      ← 최고 품질 (Nano Banana Pro). 더 비싸지만 layout 보존 최강
#   gemini-2.5-flash-image          ← legacy. aspect-ratio bug (1:1 collapse) — 권장 안 함
# GENY_NANO_BANANA_MODEL=gemini-3.1-flash-image-preview
# GENY_NANO_BANANA_TIMEOUT_MS=60000
#
# OpenAI Image — default: gpt-image-1.5 (atlas 호환성)
#   gpt-image-1.5    ← default. transparent 배경 지원 + input_fidelity:"high" 토글 가능
#   gpt-image-2      ← 2026-04 SOTA. 항상 high fidelity. 단 transparent 미지원 (atlas 에 부적합)
#   gpt-image-1-mini ← 저렴/빠름 (저해상도 미리보기용)
#   gpt-image-1      ← deprecated label, 작동은 함
# 모든 모델 organization verification 필요 (https://platform.openai.com/settings/organization/general)
# GENY_OPENAI_IMAGE_MODEL=gpt-image-1.5
# GENY_OPENAI_IMAGE_SIZE=1024x1024     # 1024x1024 / 1536x1024 / 1024x1536 / auto
# GENY_OPENAI_IMAGE_QUALITY=high       # low / medium / high / auto
# GENY_OPENAI_IMAGE_TIMEOUT_MS=120000  # high quality edit 30~90s 소요

# ----------------------------------------------------------------------------
# 어댑터 비활성 (선택)
# ----------------------------------------------------------------------------
# GENY_NANO_BANANA_DISABLED=true
# GENY_OPENAI_IMAGE_DISABLED=true
# GENY_POLLINATIONS_DISABLED=true

# ----------------------------------------------------------------------------
# 서버 인프라 (선택)
# ----------------------------------------------------------------------------
# PORT=3000
# GENY_RIG_TEMPLATES=                    # 절대 경로. 미설정 시 저장소 루트의 rig-templates/
# GENY_LOG=true                          # Fastify pino logger 활성화
