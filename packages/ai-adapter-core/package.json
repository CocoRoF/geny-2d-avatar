{
  "name": "@geny/ai-adapter-core",
  "version": "0.1.0",
  "private": true,
  "description": "docs/05 — AI 어댑터 계약 (GenerationTask/GenerationResult/Capability/AIAdapter/AdapterRegistry) + 결정론적 시드 + prompt_sha256 + provenance `ai_generated` 엔트리 빌더. 벤더 교체 가능한 재설계 계약자 인터페이스.",
  "type": "module",
  "engines": {
    "node": ">=22.11.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    },
    "./provenance": {
      "types": "./dist/provenance.d.ts",
      "import": "./dist/provenance.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:test": "tsc -p tsconfig.test.json",
    "clean": "rm -rf dist dist-test",
    "test": "pnpm build:test && node --test --test-reporter=spec 'dist-test/tests/**/*.test.js'"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "typescript": "^5.6.3"
  }
}
