{
  "name": "@geny/license-verifier",
  "version": "0.1.0",
  "private": true,
  "description": "Geny 발급자 공개키 레지스트리 기반 license.json / provenance.json 검증기. Ed25519 서명 + 번들 sha 결합 + 키 로테이션 (active/retired/revoked) + trust_scope (production/fixture) 를 구현. docs/11 §9.3 `license.verify` 의 ref impl.",
  "type": "module",
  "engines": {
    "node": ">=22.11.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "import": "./dist/verify.js"
    },
    "./canonical-json": {
      "types": "./dist/canonical-json.d.ts",
      "import": "./dist/canonical-json.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "bin": {
    "license-verifier": "./bin/license-verifier.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:test": "tsc -p tsconfig.test.json",
    "clean": "rm -rf dist dist-test",
    "test": "pnpm build:test && node --test --test-reporter=spec 'dist-test/tests/**/*.test.js'"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "typescript": "^5.6.3"
  }
}
