{
  "name": "@geny/migrator",
  "version": "0.1.0",
  "private": true,
  "description": "Geny rig 템플릿 순방향 마이그레이터 (halfbody v1.0.0→v1.3.0 체인). 세션 27/37 migrate 로직을 packaged 한다 — CLI shim `scripts/rig-template/migrate.mjs` 의 기반. docs/03 §7.3.",
  "type": "module",
  "engines": {
    "node": ">=22.11.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./migrate": {
      "types": "./dist/migrate.d.ts",
      "import": "./dist/migrate.js"
    },
    "./migrations": {
      "types": "./dist/migrations/index.d.ts",
      "import": "./dist/migrations/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:test": "tsc -p tsconfig.test.json",
    "clean": "rm -rf dist dist-test",
    "test": "pnpm build:test && node --test --test-reporter=spec 'dist-test/tests/**/*.test.js'"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "typescript": "^5.6.3"
  }
}
