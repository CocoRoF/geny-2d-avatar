{
  "name": "@geny/web-avatar-renderer",
  "version": "0.1.0",
  "private": true,
  "description": "Geny 2D Avatar 브라우저 런타임 렌더러 공통 인터페이스 — `<geny-avatar>` 가 방출하는 ready/parameterchange 이벤트와 bundle.meta 의 duck-typed 계약을 모아둔다. ADR 0007 의 어떤 렌더러 경로(A PixiJS / D 자체 WebGL2 / E 하이브리드)로 확정되어도 구현체가 의존할 상위 계약 패키지.",
  "type": "module",
  "engines": {
    "node": ">=22.11.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "import": "./dist/contracts.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:test": "tsc -p tsconfig.test.json",
    "clean": "rm -rf dist dist-test",
    "test": "pnpm build:test && node --test --test-reporter=spec 'dist-test/tests/**/*.test.js'"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "typescript": "^5.6.3"
  }
}
